{
  "schema_version": 1,
  "language_id": "as-network-sequence-claim-v1",
  "description": "Minimal AS object language for current post-handoff network-sequence claims.",
  "syntax_classes": {
    "terms": {
      "roles": ["wire", "proc", "stem"],
      "memory": ["right", "left"],
      "signals": [
        0,
        1,
        "_",
        "si",
        "standard-signal",
        "stem-init",
        "wire-r-init",
        "wire-l-init",
        "proc-r-init",
        "proc-l-init",
        "write-buf-zero",
        "write-buf-one"
      ],
      "automail": ["_", "wr", "wl", "pr", "pl"],
      "command_messages": [
        "_",
        "standard-signal",
        "stem-init",
        "wire-r-init",
        "wire-l-init",
        "proc-r-init",
        "proc-l-init",
        "write-buf-zero",
        "write-buf-one"
      ],
      "transition_statuses": [
        "idle",
        "automail-reconfigured",
        "blocked-output",
        "rejected-input",
        "routed",
        "stem-buffer-appended",
        "stem-buffer-full",
        "stem-control-selected",
        "stem-command-buffer-neighbor-delivered",
        "stem-command-buffer-self-processed",
        "stem-command-buffer-self-write-buffer-appended",
        "recipient-init-command-message-processed",
        "recipient-write-buffer-command-message-appended",
        "stem-init",
        "self-mailbox-processed",
        "self-mailbox-unsupported",
        "self-mailbox-write-buffer-appended"
      ],
      "chain_statuses": [
        "neighbor-delivery-consumed",
        "sender-not-delivered",
        "recipient-not-ready",
        "recipient-not-consumed"
      ],
      "sequence_statuses": [
        "post-handoff-signal-routed",
        "handoff-not-init-consumed",
        "followup-not-routed"
      ],
      "cell_fields": [
        "role",
        "memory",
        "upstream",
        "input",
        "output",
        "automail",
        "self_mailbox",
        "control",
        "buffer"
      ]
    },
    "sequence_formulae": {
      "predicate_symbols": ["post_handoff_signal_routed"],
      "form": "predicate(sequence_witness)"
    },
    "sequence_sentences": {
      "kinds": ["network-sequence-claim"],
      "claim_id_prefixes": ["UC-SEQUENCE-"]
    },
    "proof_objects": {
      "rules": ["manifest-example", "predicate-result"]
    },
    "substrate_sequence_claims": {
      "claim_manifest": "claims/network_sequence_claims.json",
      "certificate_manifest": "claims/network_sequence_proof_certificates.json"
    }
  }
}
